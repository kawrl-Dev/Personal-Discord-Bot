# Handle line endings automatically for all text files
* text=auto

# Force LF for source files and build scripts
*.java text eol=lf
*.kt text eol=lf
*.gradle text eol=lf
*.xml text eol=lf
*.sql text eol=lf

# Force LF for the gradle wrapper script so it runs on Linux/Mac
gradlew text eol=lf

# Denote binary files
*.jar binary
*.png binary
*.jpg binary